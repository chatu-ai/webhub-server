# ─── Authentication Configuration ──────────────────────────────────────────
# AUTH_MODE controls whether admin authentication is required.
# Options:
#   none      - No authentication required (default, open access)
#   password  - Username/password login required; issues JWT on success
AUTH_MODE=none

# Admin credentials for password mode (used only when AUTH_MODE=password)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# JWT signing secret — CHANGE THIS to a long random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# Token expiry in hours (default: 8760 = 1 year)
# Examples: 24 (1 day), 168 (1 week), 720 (30 days), 8760 (1 year)
TOKEN_EXPIRE_HOURS=8760

# ─── Server Configuration ───────────────────────────────────────────────────
HTTP_PORT=3000

# ─── Database Configuration ─────────────────────────────────────────────────
# Full path to the SQLite database file
DB_PATH=./data/webhub.db

# ─── File Upload Configuration ──────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
