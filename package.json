{
  "name": "chatu-web-hub-service",
  "version": "1.0.0",
  "description": "WebHub Backend Service - REST API server for channel management",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "fuser -k 3000/tcp 2>/dev/null; sleep 0.3; tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "register": "tsx src/cli/register.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "keywords": [
    "webhub",
    "openclaw",
    "messaging",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pino": "^8.18.0",
    "sql.js": "^1.13.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
